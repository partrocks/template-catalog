<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}PartRocks · Symfony{% endblock %}</title>
        <style>
            :root {
                color-scheme: light dark;
                --bg: #0f1419;
                --fg: #e7ecf1;
                --accent: #3d9cf5;
                --muted: #8b9aab;
                --card: #1a2332;
            }
            @media (prefers-color-scheme: light) {
                :root {
                    --bg: #f4f6f9;
                    --fg: #1a2332;
                    --accent: #0b6bcb;
                    --muted: #5c6d82;
                    --card: #fff;
                }
            }
            * { box-sizing: border-box; }
            body {
                margin: 0;
                min-height: 100vh;
                font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
                background: radial-gradient(ellipse 120% 80% at 20% 0%, rgba(61, 156, 245, 0.12), transparent 50%), var(--bg);
                color: var(--fg);
                line-height: 1.6;
            }
            main {
                max-width: 42rem;
                margin: 0 auto;
                padding: 3rem 1.5rem 4rem;
            }
            .card {
                background: var(--card);
                border-radius: 12px;
                padding: 2rem;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
                border: 1px solid rgba(127, 155, 180, 0.15);
            }
            h1 {
                font-size: 1.75rem;
                font-weight: 700;
                margin: 0 0 0.5rem;
                letter-spacing: -0.02em;
            }
            .badge {
                display: inline-block;
                font-size: 0.7rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                color: var(--accent);
                margin-bottom: 1rem;
            }
            p { margin: 0 0 1rem; color: var(--muted); }
            p strong { color: var(--fg); }
            ul { margin: 1rem 0 0; padding-left: 1.2rem; color: var(--muted); }
            li { margin-bottom: 0.35rem; }
            code {
                font-size: 0.9em;
                padding: 0.12em 0.4em;
                border-radius: 4px;
                background: rgba(127, 155, 180, 0.12);
            }
            footer {
                margin-top: 2rem;
                font-size: 0.85rem;
                color: var(--muted);
            }
            .status {
                display: inline-block;
                font-size: 0.8rem;
                font-weight: 600;
                margin-left: 0.35rem;
                padding: 0.15em 0.5em;
                border-radius: 4px;
            }
            .status--ok {
                color: #0d9f4c;
                background: rgba(13, 159, 76, 0.15);
            }
            @media (prefers-color-scheme: light) {
                .status--ok {
                    color: #067a3a;
                    background: rgba(13, 159, 76, 0.12);
                }
            }
            .status--bad {
                color: #f06363;
                background: rgba(240, 99, 99, 0.15);
            }
            .status-detail {
                display: block;
                margin-top: 0.35rem;
                font-size: 0.82rem;
                font-weight: 400;
                color: var(--muted);
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </body>
</html>
