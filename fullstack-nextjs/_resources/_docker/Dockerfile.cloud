FROM node:20-alpine

WORKDIR /app

COPY app/package.json app/package-lock.json* ./
RUN npm ci

COPY app/ /app

RUN npm run build && npm prune --omit=dev

COPY _partrocks/_deploy/hooks /opt/partrocks/hooks
RUN chmod +x /opt/partrocks/hooks/*

ENV NODE_ENV=production
ENV PORT=3000
EXPOSE 3000

CMD ["sh", "/opt/partrocks/hooks/cloud-boot.sh"]
